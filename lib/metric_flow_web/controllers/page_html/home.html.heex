<div class="min-h-[calc(100vh-4rem)]">
  <%!-- Hero Section --%>
  <section class="hero min-h-[70vh] bg-gradient-to-br from-base-200 to-base-300">
    <div class="hero-content text-center py-20">
      <div class="max-w-3xl">
        <h1 class="text-5xl sm:text-6xl font-bold tracking-tight">
          <span class="text-primary">Metric</span><span class="text-accent">Flow</span>
        </h1>
        <p class="py-6 text-xl text-base-content/70 leading-relaxed max-w-2xl mx-auto">
          Connect your marketing and financial platforms, unify your metrics,
          and let AI surface the insights that matter.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={~p"/users/register"} class="btn btn-primary btn-lg">Get Started</a>
          <a href={~p"/users/log-in"} class="btn btn-ghost btn-lg">Sign In</a>
        </div>
      </div>
    </div>
  </section>

  <%!-- Features Grid --%>
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-base-100">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-4">Everything you need to understand your data</h2>
      <p class="text-center text-base-content/60 mb-12 max-w-2xl mx-auto">
        From raw metrics to actionable insights, MetricFlow connects the dots across all your platforms.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <%!-- Integrations --%>
        <div class="card bg-base-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="card-body">
            <div class="text-primary mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </div>
            <h3 class="card-title text-lg">Platform Integrations</h3>
            <p class="text-base-content/60 text-sm">
              Connect marketing and financial platforms via OAuth. Automated daily syncs keep your data fresh, with manual triggers when you need them.
            </p>
          </div>
        </div>

        <%!-- Dashboards --%>
        <div class="card bg-base-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="card-body">
            <div class="text-primary mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="card-title text-lg">Unified Dashboards</h3>
            <p class="text-base-content/60 text-sm">
              View all your metrics in one place with cross-platform normalization. Create custom reports or start from pre-built templates.
            </p>
          </div>
        </div>

        <%!-- Correlations --%>
        <div class="card bg-base-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="card-body">
            <div class="text-primary mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
              </svg>
            </div>
            <h3 class="card-title text-lg">Correlation Analysis</h3>
            <p class="text-base-content/60 text-sm">
              Automatically discover relationships between metrics. Set goal metrics and see what's driving your results, in raw data or AI-interpreted mode.
            </p>
          </div>
        </div>

        <%!-- AI Insights --%>
        <div class="card bg-base-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="card-body">
            <div class="text-primary mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h3 class="card-title text-lg">AI Insights</h3>
            <p class="text-base-content/60 text-sm">
              Get AI-powered suggestions and anomaly detection on your data. Surface trends and opportunities you might otherwise miss.
            </p>
          </div>
        </div>

        <%!-- AI Chat --%>
        <div class="card bg-base-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="card-body">
            <div class="text-primary mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <h3 class="card-title text-lg">AI Chat</h3>
            <p class="text-base-content/60 text-sm">
              Explore your data through natural language. Ask questions, generate custom reports, and get explanations powered by LLM analysis.
            </p>
          </div>
        </div>

        <%!-- Teams & White Label --%>
        <div class="card bg-base-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="card-body">
            <div class="text-primary mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="card-title text-lg">Teams & White Label</h3>
            <p class="text-base-content/60 text-sm">
              Multi-user accounts with role-based access. Agencies can white-label the entire interface with custom branding and invite clients directly.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%!-- CTA Section --%>
  <section class="py-16 px-4 bg-base-200">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl font-bold mb-4">Ready to connect your data?</h2>
      <p class="text-base-content/60 mb-8">
        Create an account, connect your platforms, and start seeing insights in minutes.
      </p>
      <a href={~p"/users/register"} class="btn btn-primary btn-wide">Create Your Account</a>
    </div>
  </section>
</div>
