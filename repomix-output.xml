config :anderson_reports,
  ecto_repos: [AndersonReports.Repo],
  generators: [timestamp_type: :utc_datetime]

# Configures the endpoint
config :anderson_reports, AndersonReportsWeb.Endpoint,
  url: [host: "localhost"],
  adapter: Bandit.PhoenixAdapter,
  render_errors: [
    formats: [html: AndersonReportsWeb.ErrorHTML, json: AndersonReportsWeb.ErrorJSON],
    layout: false
  ],
  pubsub_server: AndersonReports.PubSub,
  live_view: [signing_salt: "ldkW9cvO"]

# Configures the mailer
#
# By default it uses the "Local" adapter which stores the emails
# locally. You can see the emails in your browser, at "/dev/mailbox".
#
# For production it's recommended to configure a different adapter
# at the `config/runtime.exs`.
