defmodule AndersonReports.MetricsTest do
  use AndersonReports.DataCase

  alias AndersonReports.Metrics

  describe "metrics" do
    alias AndersonReports.Metrics.Metric

    import AndersonReports.MetricsFixtures

    @invalid_attrs %{customer_name: nil, date: nil, external_location_id: nil, metric_key: nil, metric_label: nil, metric_name: nil, normalized_metric_name: nil, platform_external_id: nil, platform_service_type: nil, value: nil}

    test "list_metrics/0 returns all metrics" do
      metric = metric_fixture()
      assert Metrics.list_metrics() == [metric]
    end

    test "get_metric!/1 returns the metric with given id" do
      metric = metric_fixture()
      assert Metrics.get_metric!(metric.id) == metric
    end

    test "create_metric/1 with valid data creates a metric" do
      valid_attrs = %{customer_name: "some customer_name", date: ~D[2025-05-30], external_location_id: "some external_location_id", metric_key: "some metric_key", metric_label: "some metric_label", metric_name: "some metric_name", normalized_metric_name: "some normalized_metric_name", platform_external_id: "some platform_external_id", platform_service_type: "some platform_service_type", value: 120.5}

      assert {:ok, %Metric{} = metric} = Metrics.create_metric(valid_attrs)
      assert metric.customer_name == "some customer_name"
      assert metric.date == ~D[2025-05-30]
      assert metric.external_location_id == "some external_location_id"
      assert metric.metric_key == "some metric_key"
      assert metric.metric_label == "some metric_label"
      assert metric.metric_name == "some metric_name"
      assert metric.normalized_metric_name == "some normalized_metric_name"
      assert metric.platform_external_id == "some platform_external_id"
      assert metric.platform_service_type == "some platform_service_type"
      assert metric.value == 120.5
    end

    test "create_metric/1 with invalid data returns error changeset" do
      assert {:error, %Ecto.Changeset{}} = Metrics.create_metric(@invalid_attrs)
    end

    test "update_metric/2 with valid data updates the metric" do
      metric = metric_fixture()
      update_attrs = %{customer_name: "some updated customer_name", date: ~D[2025-05-31], external_location_id: "some updated external_location_id", metric_key: "some updated metric_key", metric_label: "some updated metric_label", metric_name: "some updated metric_name", normalized_metric_name: "some updated normalized_metric_name", platform_external_id: "some updated platform_external_id", platform_service_type: "some updated platform_service_type", value: 456.7}

      assert {:ok, %Metric{} = metric} = Metrics.update_metric(metric, update_attrs)
      assert metric.customer_name == "some updated customer_name"
      assert metric.date == ~D[2025-05-31]
      assert metric.external_location_id == "some updated external_location_id"
      assert metric.metric_key == "some updated metric_key"
      assert metric.metric_label == "some updated metric_label"
      assert metric.metric_name == "some updated metric_name"
      assert metric.normalized_metric_name == "some updated normalized_metric_name"
      assert metric.platform_external_id == "some updated platform_external_id"
      assert metric.platform_service_type == "some updated platform_service_type"
      assert metric.value == 456.7
    end

    test "update_metric/2 with invalid data returns error changeset" do
      metric = metric_fixture()
      assert {:error, %Ecto.Changeset{}} = Metrics.update_metric(metric, @invalid_attrs)
      assert metric == Metrics.get_metric!(metric.id)
    end

    test "delete_metric/1 deletes the metric" do
      metric = metric_fixture()
      assert {:ok, %Metric{}} = Metrics.delete_metric(metric)
      assert_raise Ecto.NoResultsError, fn -> Metrics.get_metric!(metric.id) end
    end

    test "change_metric/1 returns a metric changeset" do
      metric = metric_fixture()
      assert %Ecto.Changeset{} = Metrics.change_metric(metric)
    end
  end
end
</file>

