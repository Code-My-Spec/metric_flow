<file path="lib/anderson_reports_web/controllers/fallback_controller.ex">
defmodule AndersonReportsWeb.FallbackController do
  @moduledoc """
  Translates controller action results into valid `Plug.Conn` responses.

  See `Phoenix.Controller.action_fallback/1` for more details.
  """
  use AndersonReportsWeb, :controller

  # This clause handles errors returned by Ecto's insert/update/delete.
  def call(conn, {:error, %Ecto.Changeset{} = changeset}) do
    conn
    |> put_status(:unprocessable_entity)
    |> put_view(json: AndersonReportsWeb.ChangesetJSON)
    |> render(:error, changeset: changeset)
  end

  # This clause is an example of how to handle resources that cannot be found.
  def call(conn, {:error, :not_found}) do
    conn
    |> put_status(:not_found)
    |> put_view(html: AndersonReportsWeb.ErrorHTML, json: AndersonReportsWeb.ErrorJSON)
    |> render(:"404")
  end
end
</file>

<file path="lib/anderson_reports_web/controllers/metric_controller.ex">
defmodule AndersonReportsWeb.MetricController do
  use AndersonReportsWeb, :controller

  alias AndersonReports.Metrics
  alias AndersonReports.Metrics.Metric

  action_fallback AndersonReportsWeb.FallbackController

  def index(conn, _params) do
    metrics = Metrics.list_metrics()
    render(conn, :index, metrics: metrics)
  end

  def create(conn, %{"metric" => metric_params}) do
    with {:ok, %Metric{} = metric} <- Metrics.create_metric(metric_params) do
      conn
      |> put_status(:created)
      |> put_resp_header("location", ~p"/api/metrics/#{metric}")
      |> render(:show, metric: metric)
    end
  end

  def show(conn, %{"id" => id}) do
    metric = Metrics.get_metric!(id)
    render(conn, :show, metric: metric)
  end

  def update(conn, %{"id" => id, "metric" => metric_params}) do
    metric = Metrics.get_metric!(id)

    with {:ok, %Metric{} = metric} <- Metrics.update_metric(metric, metric_params) do
      render(conn, :show, metric: metric)
    end
  end

  def delete(conn, %{"id" => id}) do
    metric = Metrics.get_metric!(id)

    with {:ok, %Metric{}} <- Metrics.delete_metric(metric) do
      send_resp(conn, :no_content, "")
    end
  end
end
</file>

