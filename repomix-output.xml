defmodule AndersonReportsWeb.MetricControllerTest do
  use AndersonReportsWeb.ConnCase

  import AndersonReports.MetricsFixtures

  alias AndersonReports.Metrics.Metric

  @create_attrs %{
    customer_name: "some customer_name",
    date: ~D[2025-05-30],
    external_location_id: "some external_location_id",
    metric_key: "some metric_key",
    metric_label: "some metric_label",
    metric_name: "some metric_name",
    normalized_metric_name: "some normalized_metric_name",
    platform_external_id: "some platform_external_id",
    platform_service_type: "some platform_service_type",
    value: 120.5
  }
  @update_attrs %{
    customer_name: "some updated customer_name",
    date: ~D[2025-05-31],
    external_location_id: "some updated external_location_id",
    metric_key: "some updated metric_key",
    metric_label: "some updated metric_label",
    metric_name: "some updated metric_name",
    normalized_metric_name: "some updated normalized_metric_name",
    platform_external_id: "some updated platform_external_id",
    platform_service_type: "some updated platform_service_type",
    value: 456.7
  }
  @invalid_attrs %{customer_name: nil, date: nil, external_location_id: nil, metric_key: nil, metric_label: nil, metric_name: nil, normalized_metric_name: nil, platform_external_id: nil, platform_service_type: nil, value: nil}

  setup %{conn: conn} do
    {:ok, conn: put_req_header(conn, "accept", "application/json")}
  end

  describe "index" do
    test "lists all metrics", %{conn: conn} do
      conn = get(conn, ~p"/api/metrics")
      assert json_response(conn, 200)["data"] == []
    end
  end

  describe "create metric" do
    test "renders metric when data is valid", %{conn: conn} do
      conn = post(conn, ~p"/api/metrics", metric: @create_attrs)
      assert %{"id" => id} = json_response(conn, 201)["data"]

      conn = get(conn, ~p"/api/metrics/#{id}")

      assert %{
               "id" => ^id,
               "customer_name" => "some customer_name",
               "date" => "2025-05-30",
               "external_location_id" => "some external_location_id",
               "metric_key" => "some metric_key",
               "metric_label" => "some metric_label",
               "metric_name" => "some metric_name",
               "normalized_metric_name" => "some normalized_metric_name",
               "platform_external_id" => "some platform_external_id",
               "platform_service_type" => "some platform_service_type",
               "value" => 120.5
             } = json_response(conn, 200)["data"]
    end

    test "renders errors when data is invalid", %{conn: conn} do
      conn = post(conn, ~p"/api/metrics", metric: @invalid_attrs)
      assert json_response(conn, 422)["errors"] != %{}
    end
  end

  describe "update metric" do
    setup [:create_metric]

    test "renders metric when data is valid", %{conn: conn, metric: %Metric{id: id} = metric} do
      conn = put(conn, ~p"/api/metrics/#{metric}", metric: @update_attrs)
      assert %{"id" => ^id} = json_response(conn, 200)["data"]

      conn = get(conn, ~p"/api/metrics/#{id}")

      assert %{
               "id" => ^id,
               "customer_name" => "some updated customer_name",
               "date" => "2025-05-31",
               "external_location_id" => "some updated external_location_id",
               "metric_key" => "some updated metric_key",
               "metric_label" => "some updated metric_label",
               "metric_name" => "some updated metric_name",
               "normalized_metric_name" => "some updated normalized_metric_name",
               "platform_external_id" => "some updated platform_external_id",
               "platform_service_type" => "some updated platform_service_type",
               "value" => 456.7
             } = json_response(conn, 200)["data"]
    end

    test "renders errors when data is invalid", %{conn: conn, metric: metric} do
      conn = put(conn, ~p"/api/metrics/#{metric}", metric: @invalid_attrs)
      assert json_response(conn, 422)["errors"] != %{}
    end
  end

  describe "delete metric" do
    setup [:create_metric]

    test "deletes chosen metric", %{conn: conn, metric: metric} do
      conn = delete(conn, ~p"/api/metrics/#{metric}")
      assert response(conn, 204)

      assert_error_sent 404, fn ->
        get(conn, ~p"/api/metrics/#{metric}")
      end
    end
  end

  defp create_metric(_) do
    metric = metric_fixture()
    %{metric: metric}
  end
end
