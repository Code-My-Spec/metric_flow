# Google OAuth (covers login, GA4, Google Ads)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Ads (requires separate developer token - apply via Google Ads Manager)
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# Facebook / Meta (developers.facebook.com)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# QuickBooks Online (developer.intuit.com)
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret

# Mailgun (mailgun.com)
MAILGUN_API_KEY=key-your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com

# Anthropic / Claude (console.anthropic.com)
ANTHROPIC_API_KEY=REDACTED_API_KEY

# Cloak encryption key (generate with: mix phx.gen.secret 32 | base64)
# CLOAK_KEY=base64-encoded-32-byte-key
